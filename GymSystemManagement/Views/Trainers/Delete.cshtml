@model GymSystemmanagement.DAL.Models.Trainer

@{
    ViewData["Title"] = "Delete Trainer";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card p-5 shadow text-center">
                <p class="fs-3 text-primary-color mb-2">
                    Are you sure you want to delete this Trainer?
                </p>
                <p class="text-muted mb-4">
                    <strong>@Model.Name</strong> — @Model.Email
                </p>
                <div class="alert alert-warning text-start" role="alert">
                    <strong>Warning!</strong> This action cannot be undone.
                    All Trainer data will be permanently deleted.
                </div>
                <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id"
                      method="post" class="mt-4">
                    <div class="buttons d-flex justify-content-between gap-3">
                        <a asp-controller="Trainers" asp-action="Index"
                           class="btn btn-outline flex-fill">NO</a>
                        <button type="submit" class="btn btn-fill flex-fill">Yes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>